# AutonomSOC Environment Configuration
# Copy to .env and fill in your values

# ── LLM (Ollama) ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Models pulled via: ollama pull llama3.1 && ollama pull mistral

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=autonomsoc2026

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=http://localhost:8001

# ── SOC Tool Integrations ─────────────────────────────────────
THEHIVE_URL=http://localhost:9000
THEHIVE_KEY=your-thehive-api-key-here

WAZUH_API=http://localhost:55000
WAZUH_USER=wazuh
WAZUH_PASS=wazuh

MISP_URL=https://localhost:8443
MISP_KEY=your-misp-api-key-here

# ── React Dashboard ───────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── Dataset Paths (optional real datasets) ────────────────────
# BOTS_DATASET=/data/botsv3.json
# MSTIC_DATASET=/data/mstic_guide_train.csv

LOG_LEVEL=INFO
